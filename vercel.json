{
  "buildCommand": "pnpm vercel-build",
  "outputDirectory": "dist",
  "framework": "node",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/web/(.*)",
      "destination": "/web/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/web/index.html"
    }
  ]
}
